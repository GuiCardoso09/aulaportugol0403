programa
{
	
	funcao inicio()
	{
		inteiro idade [9]
		cadeia nome[9]
		inteiro n=0
		enquanto(n<=10){
			escreva("nome: ")
			leia(nome[n])
			escreva("\nDigite a idade: ")
			leia(idade[n])
			n++		 
		}
escreva(nome[1], " ", idade[1])
escreva(nome[3], " ", idade[3])
		
	}

	
}




